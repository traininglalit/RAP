@Metadata.layer: #CORE
@UI.headerInfo: {
    typeName: 'Salesorder',
    typeNamePlural: 'SalesOrders',
    description: {
        type: #STANDARD,
        label: 'SalesOrder App'
    }
}
@Search.searchable: true
annotate entity ZC_SALEHDR_BTP1 with
{
  @UI.facet: [{
      id: 'SalesorderHdr',
      purpose: #STANDARD,
      position: 10,
      label: 'SalesOrderHdr',
      type: #IDENTIFICATION_REFERENCE
  },
  {
      id: 'SalesorderItem',
      purpose: #STANDARD,
      position: 20,
      label: 'SalesOrderItem',
      type: #LINEITEM_REFERENCE,
      targetElement: '_item'
  }
  ]
  @UI.lineItem: [{ position: 1, label: 'Salesorder' }]
  @UI.identification: [{ position: 1, label: 'Salesorder' }]
  //  @UI.selectionField: [{ position: 1 }]
  @Search.defaultSearchElement: true
  Salesorder;
  @UI.lineItem: [{ position: 2, label: 'Createdon' }]
  @UI.identification: [{ position: 2, label: 'Createdon' }]
  Createdon;
  @UI.lineItem: [{ position: 3, label: 'Creationtime' }]
  @UI.identification: [{ position: 3, label: 'Creationtime' }]
  Creationtime;
  @UI.lineItem: [{ position: 4, label: 'Personname' }]
  @UI.identification: [{ position: 4, label: 'Personname' }]
  Personname;
  @UI.lineItem: [{ position: 5, label: 'Quotationdate' }]
